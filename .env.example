# Phase 1: 数据采集 + AI 摘要
ANTHROPIC_API_KEY=              # Claude API (摘要生成)

# Phase 2: 飞书生态运营
FEISHU_APP_ID=                  # 飞书应用 ID
FEISHU_APP_SECRET=              # 飞书应用密钥
FEISHU_CHAT_ID=                 # 飞书群 ID
FEISHU_BITABLE_APP_TOKEN=       # 多维表格 app_token
FEISHU_BITABLE_SOURCES_TABLE=   # 信息源表 ID
FEISHU_BITABLE_FOLLOWS_TABLE=   # 关注对象表 ID
FEISHU_BITABLE_INFOLIB_TABLE=   # 信息库表 ID
FEISHU_BITABLE_FEEDBACK_TABLE=  # 反馈表 ID
FEISHU_BITABLE_LOGS_TABLE=      # 运行日志表 ID
FEISHU_WEBHOOK_URL=             # Webhook 地址（备用）

# Phase 3: 静态网站图片
UNSPLASH_ACCESS_KEY=            # Unsplash API (免费注册)
PEXELS_API_KEY=                 # Pexels API (免费注册)
R2_ACCESS_KEY_ID=               # Cloudflare R2
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=
R2_PUBLIC_URL=                  # R2 公开访问 URL
OPENAI_API_KEY=                 # (可选) AI 图片生成

# 网站反馈表单
PUBLIC_FEEDBACK_URL=            # Cloudflare Worker 端点 (如 https://reado-api.xxx.workers.dev/api/feedback)

# Cloudflare/D1 迁移写入
READO_D1_API_BASE_URL=          # 新 Web 生产地址，如 https://reado-station-web.example.workers.dev
READO_D1_API_SECRET=            # 与 Cloudflare Worker secret READO_API_SECRET 保持一致
READO_D1_WRITE_REQUIRED=false   # true 时采集/摘要写 D1 失败会让脚本失败
READO_CONTENT_SOURCE=json       # 本地默认 json；Cloudflare 生产使用 d1
READO_REQUIRE_D1=false          # true 时 D1 不可用会直接报错而不是回退 JSON

# Web 管理员登录
READO_AUTH_SECRET=              # 会话签名密钥，建议 32+ 字节随机字符串
READO_ADMIN_USERNAME=admin      # 可选 legacy bootstrap 用户名，默认 admin
# READO_ADMIN_PASSWORD=         # 可选 legacy bootstrap 密码；普通注册账号默认是 member，管理员账号建议保存在 D1

# V1 登录 / X / Stripe
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
READO_X_BEARER_TOKEN=           # X API bearer token，用于读取账号资料
READO_BRAVE_SEARCH_API_KEY=     # 可选：Brave Search API key，用于 profile enrichment 的公开 Web Search 候选
CLOUDFLARE_AI_GATEWAY_URL=      # 可选：OpenAI-compatible chat completions endpoint，用于 profile enrichment 模型筛选
CLOUDFLARE_AI_GATEWAY_TOKEN=    # 可选：Cloudflare AI Gateway token
READO_PROFILE_ENRICHMENT_MODEL= # 可选：profile enrichment 模型名，未配置时使用 LLM_MODEL
READO_STRIPE_SECRET_KEY=
READO_STRIPE_WEBHOOK_SECRET=
READO_STRIPE_PRICE_TEST=        # Test: $0.01/month
READO_STRIPE_PRICE_PRO=         # Pro: $12/month
READO_STRIPE_PRICE_POWER=       # Power: $29/month
READO_STRIPE_PRICE_TEAM=        # Team: $99/month+
