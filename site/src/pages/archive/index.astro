---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';

import daysData from '../../data/days.json';

const days = [...daysData].reverse();
---

<BaseLayout title="Archive - reado">
  <Header />

  <main class="container content" style="margin-top: 2rem;">
    <h1 style="margin-bottom: 1.5rem;">Archive</h1>

    <ul class="archive-list">
      {days.map((day: any) => (
        <li class="archive-day">
          <div>
            <div class="archive-day__date">{day.date}</div>
          </div>
          <div class="archive-day__meta">
            {day.itemCount} items · {day.batches.join(', ')}
          </div>
        </li>
      ))}
    </ul>

    {days.length === 0 && (
      <p style="color: var(--color-text-muted); text-align: center; padding: 3rem 0;">
        No data yet. Run collection first.
      </p>
    )}
  </main>

  <Footer />
</BaseLayout>
