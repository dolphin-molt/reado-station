---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
---

<BaseLayout title="About - reado">
  <Header />

  <main class="container content" style="margin-top: 2rem;">
    <h1 style="margin-bottom: 1.5rem;">About reado</h1>

    <div style="font-size: 1.05rem; line-height: 1.8;">
      <p style="font-size: 1.3rem; font-family: var(--font-headline); font-style: italic; margin-bottom: 2rem; color: var(--color-text-secondary);">
        一个人读不完世界，一群人可以。<br />Read All. Miss Nothing.
      </p>

      <p style="margin-bottom: 1.5rem;">
        <strong>reado</strong> 是一个 AI 驱动的信息聚合平台，从 165+ 信息源自动采集 AI 领域资讯，
        经过智能去重、分类、精选，生成结构化的每日情报。
      </p>

      <h2 style="margin: 2rem 0 1rem;">信息源覆盖</h2>
      <ul style="margin-left: 1.5rem; margin-bottom: 1.5rem;">
        <li>AI 公司官方博客：OpenAI, Anthropic, Google DeepMind, Meta AI, DeepSeek...</li>
        <li>科技媒体：TechCrunch, The Verge, Ars Technica, The Decoder...</li>
        <li>中文媒体：36氪, 虎嗅, 量子位, 钛媒体, 雷锋网...</li>
        <li>开发者社区：Hacker News, Reddit, GitHub Trending, arXiv...</li>
        <li>社交平台：Twitter/X 80+ 账号追踪</li>
      </ul>

      <h2 style="margin: 2rem 0 1rem;">技术栈</h2>
      <ul style="margin-left: 1.5rem; margin-bottom: 1.5rem;">
        <li><a href="https://github.com/dolphin-molt/reado" target="_blank"><strong>reado CLI</strong></a> — 信息源采集引擎</li>
        <li><strong>Astro</strong> — 静态网站生成</li>
        <li><strong>GitHub Actions</strong> — 定时自动采集</li>
      </ul>

      <h2 style="margin: 2rem 0 1rem;">开源</h2>
      <p>
        本项目完全开源：
        <a href="https://github.com/dolphin-molt/reado-station" target="_blank" style="color: var(--color-accent);">
          github.com/dolphin-molt/reado-station
        </a>
      </p>
    </div>
  </main>

  <Footer />
</BaseLayout>
