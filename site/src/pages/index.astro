---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Hero from '../components/Hero.astro';
import NewsCard from '../components/NewsCard.astro';
import Footer from '../components/Footer.astro';

import itemsData from '../data/items.json';
import daysData from '../data/days.json';

const latestDay = daysData[daysData.length - 1];
const todayItems = itemsData.filter((item: any) => item.date === latestDay?.date);

const aiCompany = todayItems.filter((i: any) => i.category === 'ai-company');
const techMedia = todayItems.filter((i: any) => i.category === 'tech-media');
const opensource = todayItems.filter((i: any) => i.category === 'opensource');
const community = todayItems.filter((i: any) => i.category === 'community');
const twitter = todayItems.filter((i: any) => i.category === 'twitter');
const chinaMedia = todayItems.filter((i: any) => i.category === 'china-media');
const academic = todayItems.filter((i: any) => i.category === 'academic');

const allNews = [...techMedia, ...aiCompany, ...chinaMedia];
const heroPool = allNews
  .filter((i: any) => i.summary && i.summary.length > 30)
  .sort((a: any, b: any) => (b.summary?.length || 0) - (a.summary?.length || 0));

const heroMain = heroPool[0];
const heroSidebar = heroPool.slice(1, 4);
const remainingNews = allNews.filter((i: any) => i !== heroMain && !heroSidebar.includes(i));

const dateFormatted = latestDay?.date
  ? new Date(latestDay.date + 'T00:00:00').toLocaleDateString('zh-CN', {
      year: 'numeric', month: 'long', day: 'numeric', weekday: 'long',
    })
  : '';

const pageTitle = 'reado | ' + (latestDay?.date || 'AI Intelligence Station');
---

<BaseLayout title={pageTitle}>
  <Header
    date={dateFormatted}
    itemCount={todayItems.length}
    sourceCount={3}
  />

  {heroMain && (
    <Hero main={heroMain} sidebar={heroSidebar} />
  )}

  <main class="container">
    <div class="stats-bar">
      <span>Items <strong>{todayItems.length}</strong></span>
      <span>News <strong>{allNews.length}</strong></span>
      <span>Open Source <strong>{opensource.length}</strong></span>
      <span>Community <strong>{community.length}</strong></span>
      <span>Twitter <strong>{twitter.length}</strong></span>
    </div>

    {remainingNews.length > 0 && (
      <section class="news-section">
        <div class="section-header">
          <h2>News & Company</h2>
          <span class="count">{remainingNews.length}</span>
        </div>
        <div class="news-grid">
          {remainingNews.slice(0, 9).map((item: any, idx: number) => (
            <NewsCard
              title={item.title}
              url={item.url}
              summary={item.summary}
              sourceName={item.sourceName}
              category={item.category}
              imageUrl={item.imageUrl}
              publishedAt={item.publishedAt}
              showImage={idx < 3}
            />
          ))}
        </div>
      </section>
    )}

    <div class="two-col">
      <div class="two-col__main">
        {opensource.length > 0 && (
          <section class="news-section">
            <div class="section-header">
              <h2>Open Source & Papers</h2>
              <span class="count">{opensource.length + academic.length}</span>
            </div>
            <div class="news-grid news-grid--2col">
              {[...opensource, ...academic].slice(0, 6).map((item: any) => (
                <NewsCard
                  title={item.title}
                  url={item.url}
                  summary={item.summary}
                  sourceName={item.sourceName}
                  category={item.category}
                  imageUrl={item.imageUrl}
                  showImage={false}
                />
              ))}
            </div>
          </section>
        )}

        {community.length > 0 && (
          <section class="news-section">
            <div class="section-header">
              <h2>Community</h2>
              <span class="count">{community.length}</span>
            </div>
            <ul class="compact-list">
              {community.slice(0, 8).map((item: any) => (
                <li class="compact-item">
                  <div>
                    <div class="compact-item__title">
                      <a href={item.url} target="_blank" rel="noopener">{item.title}</a>
                    </div>
                    {item.summary && <p class="compact-item__summary">{item.summary}</p>}
                  </div>
                  <span class="compact-item__source">{item.sourceName}</span>
                </li>
              ))}
            </ul>
          </section>
        )}
      </div>

      <div class="two-col__sidebar">
        {twitter.length > 0 && (
          <section class="news-section">
            <div class="section-header">
              <h2>Twitter / X</h2>
              <span class="count">{twitter.length}</span>
            </div>
            <ul class="compact-list">
              {twitter.slice(0, 10).map((item: any) => (
                <li class="compact-item">
                  <div>
                    <div class="compact-item__title">
                      <a href={item.url} target="_blank" rel="noopener">{item.title}</a>
                    </div>
                    <span class="compact-item__source">{item.sourceName}</span>
                  </div>
                </li>
              ))}
            </ul>
          </section>
        )}
      </div>
    </div>
  </main>

  <Footer />
</BaseLayout>
