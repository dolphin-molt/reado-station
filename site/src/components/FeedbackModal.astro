---
import type { Lang } from '../i18n/translations';
import { t } from '../i18n/translations';

interface Props {
  lang?: Lang;
}

const { lang = 'zh' } = Astro.props;
---

<dialog class="feedback-modal" id="feedbackModal">
  <form class="feedback-form" id="feedbackForm" method="dialog">
    <button type="button" class="feedback-modal__close" id="feedbackClose" aria-label="Close">&times;</button>
    <h2 class="feedback-form__title">{t(lang, 'feedback.title')}</h2>
    <p class="feedback-form__desc">{t(lang, 'feedback.description')}</p>

    <div class="feedback-form__types">
      <label class="feedback-type">
        <input type="radio" name="type" value="missing-source" checked />
        <span>+ {t(lang, 'feedback.type.source')}</span>
      </label>
      <label class="feedback-type">
        <input type="radio" name="type" value="wrong-info" />
        <span>! {t(lang, 'feedback.type.bug')}</span>
      </label>
      <label class="feedback-type">
        <input type="radio" name="type" value="suggestion" />
        <span>* {t(lang, 'feedback.type.suggestion')}</span>
      </label>
    </div>

    <textarea
      name="message"
      class="feedback-form__textarea"
      placeholder={t(lang, 'feedback.message')}
      rows="4"
      required
    ></textarea>

    <div class="feedback-form__actions">
      <button type="submit" class="feedback-form__submit" id="feedbackSubmit">
        {t(lang, 'feedback.submit')}
      </button>
    </div>

    <p class="feedback-form__success" id="feedbackSuccess" hidden>
      {t(lang, 'feedback.success')}
    </p>
  </form>
</dialog>

<style>
  .feedback-modal {
    border: none;
    border-radius: 12px;
    padding: 0;
    max-width: 480px;
    width: 90vw;
    background: var(--color-bg, #fff);
    color: var(--color-text, #333);
    box-shadow: 0 20px 60px rgba(0,0,0,0.3);
  }

  .feedback-modal::backdrop {
    background: rgba(0,0,0,0.4);
    backdrop-filter: blur(2px);
  }

  .feedback-form {
    padding: 2rem;
    position: relative;
  }

  .feedback-modal__close {
    position: absolute;
    top: 1rem;
    right: 1rem;
    background: none;
    border: none;
    font-size: 1.5rem;
    cursor: pointer;
    opacity: 0.4;
    color: inherit;
    line-height: 1;
  }

  .feedback-modal__close:hover {
    opacity: 1;
  }

  .feedback-form__title {
    margin: 0 0 0.3rem;
    font-size: 1.3rem;
  }

  .feedback-form__desc {
    font-size: 0.85rem;
    opacity: 0.6;
    margin: 0 0 1.2rem;
  }

  .feedback-form__types {
    display: flex;
    gap: 0.5rem;
    margin-bottom: 1rem;
    flex-wrap: wrap;
  }

  .feedback-type {
    cursor: pointer;
  }

  .feedback-type input {
    display: none;
  }

  .feedback-type span {
    display: inline-block;
    padding: 0.4rem 0.8rem;
    border: 1px solid var(--color-border, #ddd);
    border-radius: 6px;
    font-size: 0.85rem;
    transition: all 0.15s;
  }

  .feedback-type input:checked + span {
    background: var(--color-accent, #c0785c);
    color: white;
    border-color: var(--color-accent, #c0785c);
  }

  .feedback-form__textarea {
    width: 100%;
    border: 1px solid var(--color-border, #ddd);
    border-radius: 8px;
    padding: 0.8rem;
    font-size: 0.9rem;
    resize: vertical;
    background: var(--color-bg, #fff);
    color: inherit;
    font-family: inherit;
    box-sizing: border-box;
  }

  .feedback-form__textarea:focus {
    outline: none;
    border-color: var(--color-accent, #c0785c);
  }

  .feedback-form__actions {
    margin-top: 1rem;
    display: flex;
    justify-content: flex-end;
  }

  .feedback-form__submit {
    padding: 0.6rem 1.5rem;
    background: var(--color-accent, #c0785c);
    color: white;
    border: none;
    border-radius: 6px;
    font-size: 0.9rem;
    cursor: pointer;
    font-weight: 500;
    transition: opacity 0.15s;
  }

  .feedback-form__submit:hover {
    opacity: 0.85;
  }

  .feedback-form__submit:disabled {
    opacity: 0.5;
    cursor: not-allowed;
  }

  .feedback-form__success {
    text-align: center;
    color: var(--color-accent, #c0785c);
    font-weight: 500;
    margin: 1rem 0 0;
  }
</style>

<script is:inline>
(function() {
  var modal = document.getElementById('feedbackModal');
  var form = document.getElementById('feedbackForm');
  var closeBtn = document.getElementById('feedbackClose');
  var submitBtn = document.getElementById('feedbackSubmit');
  var successMsg = document.getElementById('feedbackSuccess');

  // Open modal from any element with data-feedback-trigger
  document.addEventListener('click', function(e) {
    if (e.target.closest('[data-feedback-trigger]')) {
      e.preventDefault();
      modal.showModal();
      successMsg.hidden = true;
      form.reset();
    }
  });

  closeBtn.addEventListener('click', function() {
    modal.close();
  });

  modal.addEventListener('click', function(e) {
    if (e.target === modal) modal.close();
  });

  form.addEventListener('submit', function(e) {
    e.preventDefault();
    var type = form.querySelector('input[name="type"]:checked').value;
    var message = form.querySelector('textarea[name="message"]').value.trim();
    if (!message) return;

    submitBtn.disabled = true;
    submitBtn.textContent = '...';

    var labels = { 'missing-source': 'missing-source', 'wrong-info': 'bug', 'suggestion': 'enhancement' };
    var title = '[' + type + '] ' + message.slice(0, 80);
    var body = '## Feedback Type\n' + type + '\n\n## Message\n' + message + '\n\n---\n_Submitted from reado website_';

    fetch('https://api.github.com/repos/dolphin-molt/reado-station/issues', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ title: title, body: body, labels: [labels[type] || 'feedback', 'agent-todo'] })
    }).then(function(res) {
      if (res.status === 201) {
        successMsg.hidden = false;
        form.querySelector('textarea').value = '';
        setTimeout(function() { modal.close(); }, 1500);
      } else {
        // Fallback: open GitHub issue in new tab
        var url = 'https://github.com/dolphin-molt/reado-station/issues/new?title=' +
          encodeURIComponent(title) + '&body=' + encodeURIComponent(body) +
          '&labels=' + encodeURIComponent(labels[type] || 'feedback');
        window.open(url, '_blank');
        modal.close();
      }
    }).catch(function() {
      // Fallback: open GitHub issue in new tab
      var url = 'https://github.com/dolphin-molt/reado-station/issues/new?title=' +
        encodeURIComponent(title) + '&body=' + encodeURIComponent(message);
      window.open(url, '_blank');
      modal.close();
    }).finally(function() {
      submitBtn.disabled = false;
      submitBtn.textContent = form.dataset.submitLabel || '提交';
    });
  });
})();
</script>
