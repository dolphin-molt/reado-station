---
interface Props {
  title: string;
  url: string;
  summary: string;
  sourceName: string;
  category: string;
  imageUrl?: string;
  publishedAt?: string;
  showImage?: boolean;
}

const {
  title,
  url,
  summary,
  sourceName,
  category,
  imageUrl,
  publishedAt,
  showImage = true,
} = Astro.props;

const base = import.meta.env.BASE_URL;
const baseUrl = base.endsWith('/') ? base : base + '/';
const resolvedImageUrl = imageUrl?.startsWith('/') ? `${baseUrl}${imageUrl.slice(1)}` : imageUrl;

const categoryLabels: Record<string, string> = {
  'ai-company': 'AI Company',
  'tech-media': 'Tech Media',
  'opensource': 'Open Source',
  'academic': 'Academic',
  'community': 'Community',
  'twitter': 'Twitter',
  'china-media': '中文媒体',
};
---

<article class="card" data-pagefind-body>
  {showImage && imageUrl && (
    <img class="card__image" src={resolvedImageUrl} alt="" loading="lazy" />
  )}
  <div class="card__source">
    <span class={`category-tag category-tag--${category}`}>
      {categoryLabels[category] || category}
    </span>
    {' '}{sourceName}
  </div>
  <h3 class="card__title">
    <a href={url} target="_blank" rel="noopener">{title}</a>
  </h3>
  {summary && <p class="card__summary">{summary}</p>}
  {publishedAt && (
    <div class="card__meta">
      {new Date(publishedAt).toLocaleDateString('zh-CN', { month: 'short', day: 'numeric', hour: '2-digit', minute: '2-digit' })}
    </div>
  )}
</article>
