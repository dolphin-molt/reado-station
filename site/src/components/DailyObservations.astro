---
import type { Lang } from '../i18n/translations';
import { t } from '../i18n/translations';

interface Props {
  observationText?: string;
  lang?: Lang;
}

const { observationText, lang = 'zh' } = Astro.props;
---

{observationText && (
  <section class="observations">
    <div class="container">
      <h2 class="observations__title">{t(lang, 'observations.title')}</h2>
      <p class="observations__text">{observationText}</p>
    </div>
  </section>
)}
