---
import type { Lang } from '../i18n/translations';

interface NewsItem {
  title: string;
  titleZh?: string;
  url: string;
  summary: string;
  summaryZh?: string;
  sourceName: string;
  category: string;
  imageUrl?: string;
}

interface Props {
  main: NewsItem;
  sidebar: NewsItem[];
  lang?: Lang;
}

const { main, sidebar, lang = 'zh' } = Astro.props;

function d(item: NewsItem, field: 'title' | 'summary') {
  if (lang === 'zh') {
    const zhField = field === 'title' ? 'titleZh' : 'summaryZh';
    if (item[zhField]) return item[zhField];
  }
  return item[field];
}
---

<section class="hero">
  <div class="container">
    <div class="hero__grid">
      <div class="hero__main">
        <span class="source-tag">{main.sourceName}</span>
        <h1><a href={main.url} target="_blank" rel="noopener">{d(main, 'title')}</a></h1>
        <p class="summary">{d(main, 'summary')}</p>
      </div>
      <div class="hero__sidebar">
        {sidebar.map((item) => (
          <div class="hero__sidebar-item">
            <span class="source-tag">{item.sourceName}</span>
            <h3><a href={item.url} target="_blank" rel="noopener">{d(item, 'title')}</a></h3>
            <p class="summary">{d(item, 'summary')}</p>
          </div>
        ))}
      </div>
    </div>
  </div>
</section>
