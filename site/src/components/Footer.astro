---
import type { Lang } from '../i18n/translations';
import { t, localePath } from '../i18n/translations';
import FeedbackModal from './FeedbackModal.astro';

interface Props {
  lang?: Lang;
}

const { lang = 'zh' } = Astro.props;
const base = import.meta.env.BASE_URL;
---

<footer class="footer container">
  <div class="footer__logo">reado</div>
  <p>{t(lang, 'footer.slogan')}</p>
  <div class="footer__links">
    <a href={localePath(base, lang, 'about/')}>{t(lang, 'nav.about')}</a>
    <a href="#" data-feedback-trigger>{t(lang, 'footer.feedback')}</a>
  </div>
</footer>

<FeedbackModal lang={lang} />
