---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Header from '../Header.astro';
import Hero from '../Hero.astro';
import NewsCard from '../NewsCard.astro';
import Footer from '../Footer.astro';
import type { Lang } from '../../i18n/translations';
import { t, getDateLocale } from '../../i18n/translations';

import itemsData from '../../data/items.json';
import daysData from '../../data/days.json';

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;

const latestDay = daysData[daysData.length - 1];
const todayItems = itemsData.filter((item: any) => item.date === latestDay?.date);

const aiCompany = todayItems.filter((i: any) => i.category === 'ai-company');
const techMedia = todayItems.filter((i: any) => i.category === 'tech-media');
const opensource = todayItems.filter((i: any) => i.category === 'opensource');
const community = todayItems.filter((i: any) => i.category === 'community');
const twitter = todayItems.filter((i: any) => i.category === 'twitter');
const chinaMedia = todayItems.filter((i: any) => i.category === 'china-media');
const academic = todayItems.filter((i: any) => i.category === 'academic');

const allNews = [...techMedia, ...aiCompany, ...chinaMedia];
const heroPool = allNews
  .filter((i: any) => i.summary && i.summary.length > 30)
  .sort((a: any, b: any) => (b.summary?.length || 0) - (a.summary?.length || 0));

const heroMain = heroPool[0];
const heroSidebar = heroPool.slice(1, 4);
const remainingNews = allNews.filter((i: any) => i !== heroMain && !heroSidebar.includes(i));

const dateFormatted = latestDay?.date
  ? new Date(latestDay.date + 'T00:00:00').toLocaleDateString(getDateLocale(lang), {
      year: 'numeric', month: 'long', day: 'numeric', weekday: 'long',
    })
  : '';

const pageTitle = 'reado | ' + (latestDay?.date || 'AI Intelligence Station');

const feedbackEndpoint = import.meta.env.PUBLIC_FEEDBACK_URL || 'https://api.web3forms.com/submit';
const feedbackKey = import.meta.env.PUBLIC_WEB3FORMS_KEY || '';
---

<BaseLayout title={pageTitle} lang={lang}>
  <Header
    date={dateFormatted}
    itemCount={todayItems.length}
    sourceCount={3}
    lang={lang}
  />

  {heroMain && (
    <Hero main={heroMain} sidebar={heroSidebar} lang={lang} />
  )}

  <main class="container">
    <div class="stats-bar">
      <span>{t(lang, 'stats.items')} <strong>{todayItems.length}</strong></span>
      <span>{t(lang, 'stats.news')} <strong>{allNews.length}</strong></span>
      <span>{t(lang, 'stats.opensource')} <strong>{opensource.length}</strong></span>
      <span>{t(lang, 'stats.community')} <strong>{community.length}</strong></span>
      <span>{t(lang, 'stats.twitter')} <strong>{twitter.length}</strong></span>
    </div>

    {remainingNews.length > 0 && (
      <section class="news-section">
        <div class="section-header">
          <h2>{t(lang, 'section.news')}</h2>
          <span class="count">{remainingNews.length}</span>
        </div>
        <div class="news-grid">
          {remainingNews.slice(0, 9).map((item: any, idx: number) => (
            <NewsCard
              title={item.title}
              titleZh={item.titleZh}
              url={item.url}
              summary={item.summary}
              summaryZh={item.summaryZh}
              sourceName={item.sourceName}
              category={item.category}
              imageUrl={item.imageUrl}
              publishedAt={item.publishedAt}
              showImage={idx < 3}
              lang={lang}
            />
          ))}
        </div>
      </section>
    )}

    <div class="two-col">
      <div class="two-col__main">
        {opensource.length > 0 && (
          <section class="news-section">
            <div class="section-header">
              <h2>{t(lang, 'section.opensource')}</h2>
              <span class="count">{opensource.length + academic.length}</span>
            </div>
            <div class="news-grid news-grid--2col">
              {[...opensource, ...academic].slice(0, 6).map((item: any) => (
                <NewsCard
                  title={item.title}
                  titleZh={item.titleZh}
                  url={item.url}
                  summary={item.summary}
                  summaryZh={item.summaryZh}
                  sourceName={item.sourceName}
                  category={item.category}
                  imageUrl={item.imageUrl}
                  showImage={false}
                  lang={lang}
                />
              ))}
            </div>
          </section>
        )}

        {community.length > 0 && (
          <section class="news-section">
            <div class="section-header">
              <h2>{t(lang, 'section.community')}</h2>
              <span class="count">{community.length}</span>
            </div>
            <ul class="compact-list">
              {community.slice(0, 8).map((item: any) => {
                const dTitle = lang === 'zh' && item.titleZh ? item.titleZh : item.title;
                const dSummary = lang === 'zh' && item.summaryZh ? item.summaryZh : item.summary;
                return (
                <li class="compact-item">
                  <div>
                    <div class="compact-item__title">
                      <a href={item.url} target="_blank" rel="noopener">{dTitle}</a>
                    </div>
                    {dSummary && <p class="compact-item__summary">{dSummary}</p>}
                  </div>
                  <span class="compact-item__source">{item.sourceName}</span>
                </li>
                );
              })}
            </ul>
          </section>
        )}
      </div>

      <div class="two-col__sidebar">
        {twitter.length > 0 && (
          <section class="news-section">
            <div class="section-header">
              <h2>{t(lang, 'section.twitter')}</h2>
              <span class="count">{twitter.length}</span>
            </div>
            <ul class="compact-list">
              {twitter.slice(0, 10).map((item: any) => {
                const dTitle = lang === 'zh' && item.titleZh ? item.titleZh : item.title;
                return (
                <li class="compact-item">
                  <div>
                    <div class="compact-item__title">
                      <a href={item.url} target="_blank" rel="noopener">{dTitle}</a>
                    </div>
                    <span class="compact-item__source">{item.sourceName}</span>
                  </div>
                </li>
                );
              })}
            </ul>
          </section>
        )}
      </div>
    </div>
  </main>

  <div class="feedback-section container" id="feedback">
    <p class="feedback-label">{t(lang, 'feedback.cta')}</p>
    <form class="feedback-form" id="feedbackForm"
      data-endpoint={feedbackEndpoint}
      data-key={feedbackKey}>
      <input
        type="text"
        name="source"
        class="feedback-input"
        placeholder={t(lang, 'feedback.placeholder')}
        required
      />
      <button type="submit" class="feedback-submit">{t(lang, 'feedback.submit')}</button>
    </form>
    <p class="feedback-success" id="feedbackSuccess" style="display:none">{t(lang, 'feedback.success')}</p>
  </div>

  <script is:inline>
    document.getElementById('feedbackForm')?.addEventListener('submit', async function(e) {
      e.preventDefault();
      const input = this.querySelector('input[name="source"]');
      const btn = this.querySelector('button[type="submit"]');
      const value = input?.value?.trim();
      if (!value) return;

      const endpoint = this.dataset.endpoint;
      const key = this.dataset.key;
      btn.disabled = true;

      try {
        const isWorker = endpoint.includes('/api/feedback');
        const body = isWorker
          ? { source: value }
          : { access_key: key, subject: '信息源请求: ' + value, message: value, from_name: 'reado feedback' };

        const res = await fetch(endpoint, {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify(body),
        });

        if (res.ok) {
          input.value = '';
          document.getElementById('feedbackSuccess').style.display = 'block';
          setTimeout(() => { document.getElementById('feedbackSuccess').style.display = 'none'; }, 3000);
        }
      } catch (_) {}
      btn.disabled = false;
    });
  </script>

  <Footer lang={lang} />
</BaseLayout>

<style>
  .feedback-section {
    margin-top: 2rem;
    padding: 1.5rem 0;
    border-top: 1px solid var(--color-rule);
    text-align: center;
  }
  .feedback-label {
    font-size: 0.9rem;
    color: var(--color-text-secondary);
    margin-bottom: 0.75rem;
  }
  .feedback-form {
    display: flex;
    justify-content: center;
    gap: 0.5rem;
    max-width: 480px;
    margin: 0 auto;
  }
  .feedback-input {
    flex: 1;
    padding: 0.5rem 0.75rem;
    border: 1px solid var(--color-rule);
    border-radius: 4px;
    font-size: 0.9rem;
    background: var(--color-bg);
    color: var(--color-text);
  }
  .feedback-input:focus {
    outline: none;
    border-color: var(--color-text);
  }
  .feedback-submit {
    padding: 0.5rem 1rem;
    border: 1px solid var(--color-text);
    border-radius: 4px;
    background: var(--color-text);
    color: var(--color-bg);
    font-size: 0.9rem;
    cursor: pointer;
    white-space: nowrap;
  }
  .feedback-submit:hover {
    opacity: 0.85;
  }
  .feedback-success {
    font-size: 0.85rem;
    color: var(--color-text-secondary);
    margin-top: 0.5rem;
  }
</style>
