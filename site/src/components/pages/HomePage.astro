---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Header from '../Header.astro';
import DailyObservations from '../DailyObservations.astro';
import KeyStories from '../KeyStories.astro';
import NewsCard from '../NewsCard.astro';
import Footer from '../Footer.astro';
import type { Lang } from '../../i18n/translations';
import { t, getDateLocale } from '../../i18n/translations';

import itemsData from '../../data/items.json';
import daysData from '../../data/days.json';
import digestsData from '../../data/digests.json';

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;
const INITIAL_SHOW = 12;

const latestDay = daysData[daysData.length - 1];
const todayItems = itemsData.filter((item: any) => item.date === latestDay?.date);

const contributingSources = [...new Set(todayItems.map((i: any) => i.sourceName).filter(Boolean))].length;

// Category mapping
const CATEGORIES = [
  { id: 'all',        label: lang === 'zh' ? '全部' : 'All' },
  { id: 'news',       label: lang === 'zh' ? '新闻' : 'News',       cats: ['tech-media', 'ai-company', 'china-media'] },
  { id: 'opensource',  label: lang === 'zh' ? '开源 & 论文' : 'Open Source', cats: ['opensource', 'academic'] },
  { id: 'community',  label: lang === 'zh' ? '社区' : 'Community',   cats: ['community'] },
  { id: 'twitter',    label: 'Twitter / X',                          cats: ['twitter'] },
];

// Count per category group
const catCounts: Record<string, number> = { all: todayItems.length };
for (const c of CATEGORIES) {
  if (c.id !== 'all') {
    catCounts[c.id] = todayItems.filter((i: any) => c.cats?.includes(i.category)).length;
  }
}

// Map each item to its filter group
function getFilterGroup(category: string): string {
  for (const c of CATEGORIES) {
    if (c.cats?.includes(category)) return c.id;
  }
  return 'news';
}

const dateFormatted = latestDay?.date
  ? new Date(latestDay.date + 'T00:00:00').toLocaleDateString(getDateLocale(lang), {
      year: 'numeric', month: 'long', day: 'numeric', weekday: 'long',
    })
  : '';

// Digest data for today
const todayDigest = (digestsData as any[]).find((d: any) => d.date === latestDay?.date);
const observationText = todayDigest?.observationText || '';
const clusters = todayDigest?.clusters || [];

// Key stories: top 5 from digest clusters, each with impact/why-it-matters
const keyStories: { title: string; summary: string; sources: { name: string; url: string }[]; impact?: string; cluster: string }[] = [];
if (clusters.length > 0) {
  for (const cluster of clusters) {
    for (const story of cluster.stories) {
      keyStories.push({ ...story, cluster: cluster.name });
      if (keyStories.length >= 5) break;
    }
    if (keyStories.length >= 5) break;
  }
}

const gridItems = todayItems;

const pageTitle = 'reado | ' + (latestDay?.date || 'AI Intelligence Station');
const moreLabel = lang === 'zh' ? '显示更多' : 'Show more';
const allItemsLabel = lang === 'zh' ? `全部 ${todayItems.length} 条资讯` : `All ${todayItems.length} Items`;
---

<BaseLayout title={pageTitle} lang={lang}>
  <Header
    date={dateFormatted}
    itemCount={todayItems.length}
    sourceCount={contributingSources}
    lang={lang}
  />

  <!-- 1. 今日观察 — 页面第一焦点 -->
  {observationText && (
    <DailyObservations observationText={observationText} lang={lang} />
  )}

  <!-- 2. 关键事件 — 5 条最重要的新闻 -->
  {keyStories.length > 0 && (
    <KeyStories stories={keyStories} lang={lang} />
  )}

  <!-- 3. 全部资讯 — 默认折叠 -->
  <main class="container">
    <details class="all-items-details" id="allItemsDetails">
      <summary class="all-items-summary">
        <h2 class="all-items-title">{allItemsLabel}</h2>
        <span class="all-items-chevron"></span>
      </summary>

      <!-- Category filter pills -->
      <nav class="filter-bar" id="categoryPills">
        {CATEGORIES.map((c) => (
          <button
            data-filter={c.id}
            class={c.id === 'all' ? 'active' : ''}
          >
            {c.label}
            {catCounts[c.id] > 0 && <span class="pill-count">{catCounts[c.id]}</span>}
          </button>
        ))}
      </nav>

      <!-- Unified grid -->
      <section class="news-section" id="newsGrid">
        <div class="news-grid">
          {gridItems.map((item: any, idx: number) => (
            <div class="card-wrap" data-group={getFilterGroup(item.category)} data-index={idx}>
              <NewsCard
                title={item.title}
                titleZh={item.titleZh}
                url={item.url}
                summary={item.summary}
                summaryZh={item.summaryZh}
                sourceName={item.sourceName}
                category={item.category}
                imageUrl={item.imageUrl}
                publishedAt={item.publishedAt}
                showImage={idx < 6}
                lang={lang}
              />
            </div>
          ))}
        </div>
        <button class="show-more" id="showMoreBtn">{moreLabel}</button>
      </section>
    </details>
  </main>

  <Footer lang={lang} />
</BaseLayout>

<style>
  .card-wrap {
    display: block;
  }
  .card-wrap[data-visible="false"] {
    display: none;
  }

  .all-items-details {
    margin-top: 2rem;
  }

  .all-items-summary {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    cursor: pointer;
    list-style: none;
    padding: 1rem 0;
    border-top: 1px dashed var(--color-border, #ddd);
    user-select: none;
  }

  .all-items-summary::-webkit-details-marker {
    display: none;
  }

  .all-items-summary .all-items-title {
    margin: 0;
    font-size: 1.1rem;
    opacity: 0.7;
  }

  .all-items-chevron {
    display: inline-block;
    width: 0.5em;
    height: 0.5em;
    border-right: 2px solid currentColor;
    border-bottom: 2px solid currentColor;
    transform: rotate(-45deg);
    transition: transform 0.2s;
    opacity: 0.5;
  }

  .all-items-details[open] .all-items-chevron {
    transform: rotate(45deg);
  }
</style>

<script is:inline define:vars={{ INITIAL_SHOW }}>
  (function() {
    var pills = document.querySelectorAll('#categoryPills button');
    var wraps = document.querySelectorAll('.card-wrap');
    var moreBtn = document.getElementById('showMoreBtn');
    var currentFilter = 'all';
    var showCount = INITIAL_SHOW;

    function render() {
      var visible = 0;
      var total = 0;
      wraps.forEach(function(w) {
        var group = w.getAttribute('data-group');
        var matchFilter = currentFilter === 'all' || group === currentFilter;
        if (matchFilter) {
          total++;
          if (visible < showCount) {
            w.setAttribute('data-visible', 'true');
            visible++;
          } else {
            w.setAttribute('data-visible', 'false');
          }
        } else {
          w.setAttribute('data-visible', 'false');
        }
      });
      if (moreBtn) {
        moreBtn.style.display = visible < total ? 'block' : 'none';
      }
    }

    pills.forEach(function(btn) {
      btn.addEventListener('click', function() {
        pills.forEach(function(b) { b.classList.remove('active'); });
        btn.classList.add('active');
        currentFilter = btn.getAttribute('data-filter') || 'all';
        showCount = INITIAL_SHOW;
        render();
      });
    });

    if (moreBtn) {
      moreBtn.addEventListener('click', function() {
        showCount += INITIAL_SHOW;
        render();
      });
    }

    render();
  })();
</script>
