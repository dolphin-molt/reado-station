---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Header from '../Header.astro';
import Hero from '../Hero.astro';
import NewsCard from '../NewsCard.astro';
import Footer from '../Footer.astro';
import type { Lang } from '../../i18n/translations';
import { t, getDateLocale } from '../../i18n/translations';

import itemsData from '../../data/items.json';
import daysData from '../../data/days.json';

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;

const latestDay = daysData[daysData.length - 1];
const todayItems = itemsData.filter((item: any) => item.date === latestDay?.date);

const aiCompany = todayItems.filter((i: any) => i.category === 'ai-company');
const contributingSources = [...new Set(todayItems.map((i: any) => i.sourceName).filter(Boolean))].length;
const techMedia = todayItems.filter((i: any) => i.category === 'tech-media');
const opensource = todayItems.filter((i: any) => i.category === 'opensource');
const community = todayItems.filter((i: any) => i.category === 'community');
const twitter = todayItems.filter((i: any) => i.category === 'twitter');
const chinaMedia = todayItems.filter((i: any) => i.category === 'china-media');
const academic = todayItems.filter((i: any) => i.category === 'academic');

const allNews = [...techMedia, ...aiCompany, ...chinaMedia];
const heroPool = allNews
  .filter((i: any) => i.summary && i.summary.length > 30)
  .sort((a: any, b: any) => (b.summary?.length || 0) - (a.summary?.length || 0));

const heroMain = heroPool[0];
const heroSidebar = heroPool.slice(1, 4);
const remainingNews = allNews.filter((i: any) => i !== heroMain && !heroSidebar.includes(i));

const dateFormatted = latestDay?.date
  ? new Date(latestDay.date + 'T00:00:00').toLocaleDateString(getDateLocale(lang), {
      year: 'numeric', month: 'long', day: 'numeric', weekday: 'long',
    })
  : '';

const pageTitle = 'reado | ' + (latestDay?.date || 'AI Intelligence Station');

const feedbackEndpoint = import.meta.env.PUBLIC_FEEDBACK_URL || '';
---

<BaseLayout title={pageTitle} lang={lang}>
  <Header
    date={dateFormatted}
    itemCount={todayItems.length}
    sourceCount={contributingSources}
    lang={lang}
  />

  {heroMain && (
    <Hero main={heroMain} sidebar={heroSidebar} lang={lang} />
  )}

  <main class="container">
    <div class="stats-bar">
      <span>{t(lang, 'stats.items')} <strong>{todayItems.length}</strong></span>
      <span>{t(lang, 'stats.news')} <strong>{allNews.length}</strong></span>
      <span>{t(lang, 'stats.opensource')} <strong>{opensource.length}</strong></span>
      <span>{t(lang, 'stats.community')} <strong>{community.length}</strong></span>
      <span>{t(lang, 'stats.twitter')} <strong>{twitter.length}</strong></span>
    </div>

    {remainingNews.length > 0 && (
      <section class="news-section">
        <div class="section-header">
          <h2>{t(lang, 'section.news')}</h2>
          <span class="count">{remainingNews.length}</span>
        </div>
        <div class="news-grid">
          {remainingNews.map((item: any, idx: number) => (
            <NewsCard
              title={item.title}
              titleZh={item.titleZh}
              url={item.url}
              summary={item.summary}
              summaryZh={item.summaryZh}
              sourceName={item.sourceName}
              category={item.category}
              imageUrl={item.imageUrl}
              publishedAt={item.publishedAt}
              showImage={idx < 3}
              lang={lang}
            />
          ))}
        </div>
      </section>
    )}

    <div class="two-col">
      <div class="two-col__main">
        {opensource.length > 0 && (
          <section class="news-section">
            <div class="section-header">
              <h2>{t(lang, 'section.opensource')}</h2>
              <span class="count">{opensource.length + academic.length}</span>
            </div>
            <div class="news-grid news-grid--2col">
              {[...opensource, ...academic].map((item: any) => (
                <NewsCard
                  title={item.title}
                  titleZh={item.titleZh}
                  url={item.url}
                  summary={item.summary}
                  summaryZh={item.summaryZh}
                  sourceName={item.sourceName}
                  category={item.category}
                  imageUrl={item.imageUrl}
                  showImage={false}
                  lang={lang}
                />
              ))}
            </div>
          </section>
        )}

        {community.length > 0 && (
          <section class="news-section">
            <div class="section-header">
              <h2>{t(lang, 'section.community')}</h2>
              <span class="count">{community.length}</span>
            </div>
            <ul class="compact-list">
              {community.map((item: any) => {
                const dTitle = lang === 'zh' && item.titleZh ? item.titleZh : item.title;
                const dSummary = lang === 'zh' && item.summaryZh ? item.summaryZh : item.summary;
                return (
                <li class="compact-item">
                  <div>
                    <div class="compact-item__title">
                      <a href={item.url} target="_blank" rel="noopener">{dTitle}</a>
                    </div>
                    {dSummary && <p class="compact-item__summary">{dSummary}</p>}
                  </div>
                  <span class="compact-item__source">{item.sourceName}</span>
                </li>
                );
              })}
            </ul>
          </section>
        )}
      </div>

      <div class="two-col__sidebar">
        {twitter.length > 0 && (
          <section class="news-section">
            <div class="section-header">
              <h2>{t(lang, 'section.twitter')}</h2>
              <span class="count">{twitter.length}</span>
            </div>
            <ul class="compact-list">
              {twitter.map((item: any) => {
                const dTitle = lang === 'zh' && item.titleZh ? item.titleZh : item.title;
                return (
                <li class="compact-item">
                  <div>
                    <div class="compact-item__title">
                      <a href={item.url} target="_blank" rel="noopener">{dTitle}</a>
                    </div>
                    <span class="compact-item__source">{item.sourceName}</span>
                  </div>
                </li>
                );
              })}
            </ul>
          </section>
        )}
      </div>
    </div>
  </main>

  <div class="feedback-section container" id="feedback">
    <h3 class="feedback-title">{t(lang, 'feedback.title')}</h3>
    <p class="feedback-desc">{t(lang, 'feedback.description')}</p>
    <form class="feedback-form" id="feedbackForm" data-endpoint={feedbackEndpoint}>
      <div class="feedback-row">
        <input type="text" name="name" class="feedback-input" placeholder={t(lang, 'feedback.name')} required />
        <input type="email" name="email" class="feedback-input" placeholder={t(lang, 'feedback.email')} required />
      </div>
      <select name="type" class="feedback-select">
        <option value="source-request">{t(lang, 'feedback.type.source')}</option>
        <option value="bug">{t(lang, 'feedback.type.bug')}</option>
        <option value="suggestion">{t(lang, 'feedback.type.suggestion')}</option>
      </select>
      <textarea name="message" class="feedback-textarea" rows="3" placeholder={t(lang, 'feedback.message')} required></textarea>
      <button type="submit" class="feedback-submit">{t(lang, 'feedback.submit')}</button>
    </form>
    <p class="feedback-success" id="feedbackSuccess" style="display:none">{t(lang, 'feedback.success')}</p>
  </div>

  <script is:inline>
    document.getElementById('feedbackForm')?.addEventListener('submit', async function(e) {
      e.preventDefault();
      const btn = this.querySelector('button[type="submit"]');
      const endpoint = this.dataset.endpoint;
      if (!endpoint) return;

      const data = {
        name: this.querySelector('[name="name"]').value.trim(),
        email: this.querySelector('[name="email"]').value.trim(),
        type: this.querySelector('[name="type"]').value,
        message: this.querySelector('[name="message"]').value.trim(),
      };
      if (!data.name || !data.email || !data.message) return;

      btn.disabled = true;
      try {
        const res = await fetch(endpoint, {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify(data),
        });
        if (res.ok) {
          this.reset();
          document.getElementById('feedbackSuccess').style.display = 'block';
          setTimeout(() => { document.getElementById('feedbackSuccess').style.display = 'none'; }, 4000);
        }
      } catch (_) {}
      btn.disabled = false;
    });
  </script>

  <Footer lang={lang} />
</BaseLayout>

<style>
  .feedback-section {
    margin-top: 2rem;
    padding: 2rem 0;
    border-top: 1px solid var(--color-rule);
  }
  .feedback-title {
    font-size: 1.2rem;
    font-weight: 600;
    margin-bottom: 0.25rem;
    text-align: center;
  }
  .feedback-desc {
    font-size: 0.85rem;
    color: var(--color-text-secondary);
    margin-bottom: 1.25rem;
    text-align: center;
  }
  .feedback-form {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
    max-width: 520px;
    margin: 0 auto;
  }
  .feedback-row {
    display: flex;
    gap: 0.75rem;
  }
  .feedback-row .feedback-input {
    flex: 1;
  }
  .feedback-input,
  .feedback-select,
  .feedback-textarea {
    padding: 0.6rem 0.75rem;
    border: 1px solid var(--color-rule);
    border-radius: 4px;
    font-size: 0.9rem;
    background: var(--color-bg);
    color: var(--color-text);
    font-family: inherit;
    width: 100%;
    box-sizing: border-box;
  }
  .feedback-input:focus,
  .feedback-select:focus,
  .feedback-textarea:focus {
    outline: none;
    border-color: var(--color-text);
  }
  .feedback-textarea {
    resize: vertical;
    min-height: 60px;
  }
  .feedback-submit {
    padding: 0.6rem 1.5rem;
    border: 1px solid var(--color-text);
    border-radius: 4px;
    background: var(--color-text);
    color: var(--color-bg);
    font-size: 0.9rem;
    cursor: pointer;
    align-self: flex-end;
  }
  .feedback-submit:hover {
    opacity: 0.85;
  }
  .feedback-success {
    font-size: 0.85rem;
    color: var(--color-text-secondary);
    margin-top: 0.5rem;
    text-align: center;
  }
  @media (max-width: 480px) {
    .feedback-row {
      flex-direction: column;
    }
  }
</style>
