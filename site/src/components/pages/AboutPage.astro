---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Header from '../Header.astro';
import Footer from '../Footer.astro';
import type { Lang } from '../../i18n/translations';
import { t } from '../../i18n/translations';

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;
---

<BaseLayout title={`${t(lang, 'about.title')} - reado`} lang={lang}>
  <Header lang={lang} />

  <main class="container content" style="margin-top: 2rem;">
    <h1 style="margin-bottom: 1.5rem;">{t(lang, 'about.title')}</h1>

    <div style="font-size: 1.05rem; line-height: 1.8;">
      <p style="font-size: 1.3rem; font-family: var(--font-headline); font-style: italic; margin-bottom: 2rem; color: var(--color-text-secondary);">
        {t(lang, 'about.subtitle')}
      </p>

      <p style="margin-bottom: 1.5rem;">
        {t(lang, 'about.description')}
      </p>

      <h2 style="margin: 2rem 0 1rem;">{t(lang, 'about.vision.title')}</h2>
      <p style="margin-bottom: 1.5rem;">{t(lang, 'about.vision.text')}</p>

      <h2 style="margin: 2rem 0 1rem;">{t(lang, 'about.sources.title')}</h2>
      <p style="margin-bottom: 1.5rem;">{t(lang, 'about.sources.text')}</p>

      <h2 style="margin: 2rem 0 1rem;">{t(lang, 'about.how.title')}</h2>
      <p style="margin-bottom: 1.5rem;">{t(lang, 'about.how.text')}</p>

      <h2 style="margin: 2rem 0 1rem;">{t(lang, 'about.join.title')}</h2>
      <p>
        {t(lang, 'about.join.text')}
        {' '}
        <a href="https://github.com/dolphin-molt/reado-station" target="_blank" style="color: var(--color-accent);">
          GitHub
        </a>
      </p>

      <h2 style="margin: 2rem 0 1rem;">{t(lang, 'feedback.title')}</h2>
      <p style="margin-bottom: 1.5rem;">{t(lang, 'feedback.description')}</p>
      <div class="feedback-buttons">
        <a href="https://github.com/dolphin-molt/reado-station/issues/new?template=missing-source.yml" target="_blank" class="feedback-btn feedback-btn--source">
          {t(lang, 'feedback.missing')}
        </a>
        <a href="https://github.com/dolphin-molt/reado-station/issues/new?template=wrong-info.yml" target="_blank" class="feedback-btn feedback-btn--bug">
          {t(lang, 'feedback.bug')}
        </a>
        <a href="https://github.com/dolphin-molt/reado-station/issues/new?template=suggestion.yml" target="_blank" class="feedback-btn feedback-btn--idea">
          {t(lang, 'feedback.suggestion')}
        </a>
      </div>
    </div>
  </main>

  <style>
    .feedback-buttons {
      display: flex;
      gap: 1rem;
      flex-wrap: wrap;
    }
    .feedback-btn {
      display: inline-block;
      padding: 0.6rem 1.2rem;
      border: 1px solid var(--color-border);
      text-decoration: none;
      color: var(--color-text);
      font-size: 0.95rem;
      transition: all 0.15s ease;
    }
    .feedback-btn:hover {
      background: var(--color-text);
      color: var(--color-bg);
      border-color: var(--color-text);
    }
    .feedback-btn--source::before { content: '+ '; }
    .feedback-btn--bug::before { content: '! '; }
    .feedback-btn--idea::before { content: '* '; }
  </style>

  <Footer lang={lang} />
</BaseLayout>
