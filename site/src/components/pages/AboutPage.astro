---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Header from '../Header.astro';
import Footer from '../Footer.astro';
import type { Lang } from '../../i18n/translations';
import { t } from '../../i18n/translations';

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;
---

<BaseLayout title={`${t(lang, 'about.title')} - reado`} lang={lang}>
  <Header lang={lang} />

  <main class="container content" style="margin-top: 2rem;">
    <h1 style="margin-bottom: 1.5rem;">{t(lang, 'about.title')}</h1>

    <div style="font-size: 1.05rem; line-height: 1.8;">
      <p style="font-size: 1.3rem; font-family: var(--font-headline); font-style: italic; margin-bottom: 2rem; color: var(--color-text-secondary);">
        {t(lang, 'about.subtitle')}
      </p>

      <p style="margin-bottom: 1.5rem;">
        {t(lang, 'about.description')}
      </p>

      <h2 style="margin: 2rem 0 1rem;">{t(lang, 'about.vision.title')}</h2>
      <p style="margin-bottom: 1.5rem;">{t(lang, 'about.vision.text')}</p>

      <h2 style="margin: 2rem 0 1rem;">{t(lang, 'about.sources.title')}</h2>
      <p style="margin-bottom: 1.5rem;">{t(lang, 'about.sources.text')}</p>

      <h2 style="margin: 2rem 0 1rem;">{t(lang, 'about.how.title')}</h2>
      <p style="margin-bottom: 1.5rem;">{t(lang, 'about.how.text')}</p>

      <h2 style="margin: 2rem 0 1rem;">{t(lang, 'about.join.title')}</h2>
      <p>
        {t(lang, 'about.join.text')}
        {' '}
        <a href="https://github.com/dolphin-molt/reado-station" target="_blank" style="color: var(--color-accent);">
          GitHub
        </a>
      </p>
    </div>
  </main>

  <Footer lang={lang} />
</BaseLayout>
