---
interface Props {
  date?: string;
  itemCount?: number;
  sourceCount?: number;
}

const { date, itemCount = 0, sourceCount = 0 } = Astro.props;
const base = import.meta.env.BASE_URL;

const today = date || new Date().toLocaleDateString('zh-CN', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
  weekday: 'long',
});
---

<header class="masthead container">
  <div class="masthead__logo">
    <a href={base}>reado</a>
  </div>
  <div class="masthead__tagline">Read All. Miss Nothing.</div>
  <div class="masthead__meta">
    <span>{today}</span>
    {sourceCount > 0 && <span>{sourceCount} 信息源</span>}
    {itemCount > 0 && <span>{itemCount} 条资讯</span>}
  </div>
</header>
<nav class="masthead__nav container">
  <a href={base} class="active">Today</a>
  <a href={`${base}archive/`}>Archive</a>
  <a href={`${base}about/`}>About</a>
</nav>
