---
import type { Lang } from '../i18n/translations';
import { t } from '../i18n/translations';

interface DigestStory {
  title: string;
  summary: string;
  sources: { name: string; url: string }[];
  impact?: string;
}

interface DigestCluster {
  name: string;
  stories: DigestStory[];
}

interface Props {
  clusters: DigestCluster[];
  lang?: Lang;
}

const { clusters, lang = 'zh' } = Astro.props;

// Cluster icon mapping
const clusterIcons: Record<string, string> = {
  '重大新闻': '!',
  '公司动态': 'C',
  '论文与开源': '</>',
  '社区热点': '#',
};
---

<section class="clusters" id="topicClusters">
  <div class="container">
    <h2 class="clusters__title">{t(lang, 'clusters.title')}</h2>

    <div class="clusters__tabs" id="clusterTabs">
      {clusters.map((cluster, idx) => (
        <button
          class={idx === 0 ? 'active' : ''}
          data-cluster={idx}
        >
          <span class="clusters__tab-icon">{clusterIcons[cluster.name] || '>'}</span>
          {cluster.name}
          <span class="clusters__tab-count">{cluster.stories.length}</span>
        </button>
      ))}
    </div>

    <div class="clusters__panels">
      {clusters.map((cluster, cIdx) => (
        <div
          class={`clusters__panel ${cIdx === 0 ? 'active' : ''}`}
          data-panel={cIdx}
        >
          {cluster.stories.map((story) => (
            <div class="clusters__story">
              <h3 class="clusters__story-title">
                {story.sources[0]?.url ? (
                  <a href={story.sources[0].url} target="_blank" rel="noopener">{story.title}</a>
                ) : story.title}
              </h3>
              <p class="clusters__story-summary">{story.summary.slice(0, 180)}</p>
              {story.sources.length > 0 && (
                <div class="clusters__sources">
                  {story.sources.slice(0, 4).map((src) => (
                    <a href={src.url} target="_blank" rel="noopener" class="clusters__source-tag">
                      {src.name}
                    </a>
                  ))}
                  {story.sources.length > 4 && (
                    <span class="clusters__source-more">+{story.sources.length - 4}</span>
                  )}
                </div>
              )}
            </div>
          ))}
        </div>
      ))}
    </div>
  </div>
</section>

<script is:inline>
(function() {
  var tabs = document.querySelectorAll('#clusterTabs button');
  var panels = document.querySelectorAll('.clusters__panel');

  tabs.forEach(function(tab) {
    tab.addEventListener('click', function() {
      var idx = tab.getAttribute('data-cluster');
      tabs.forEach(function(t) { t.classList.remove('active'); });
      panels.forEach(function(p) { p.classList.remove('active'); });
      tab.classList.add('active');
      var target = document.querySelector('.clusters__panel[data-panel="' + idx + '"]');
      if (target) target.classList.add('active');
    });
  });
})();
</script>
