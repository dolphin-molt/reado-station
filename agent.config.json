{
  "_doc": "Agent 运营配置（可移植版本）。机器相关的路径放 agent.config.local.json（已 gitignore）。",

  "paths": {
    "station": ".",
    "reado": "",
    "twitterWatchlist": "~/.reado/twitter-watchlist.txt",
    "dailyOutput": "~/ai-daily"
  },

  "github": {
    "repo": "dolphin-molt/reado-station",
    "readoRepo": "dolphin-molt/reado",
    "siteUrl": "https://reado.theopcapp.com",
    "feedbackLabel": "agent-todo"
  },

  "collect": {
    "defaultMode": "all",
    "morningBefore": 14,
    "schedule": {
      "morning": "08:15",
      "evening": "18:15"
    }
  },

  "translate": {
    "provider": "siliconflow",
    "model": "Qwen/Qwen3-8B",
    "envKey": "SILICONFLOW_API_KEY",
    "batchSize": 5,
    "concurrency": 3,
    "timeout": 30000
  },

  "sourceHealth": {
    "maxConsecutiveFailures": 3,
    "autoDisable": true
  },

  "limits": {
    "completedActionsKeep": 20,
    "recentGapsKeep": 50,
    "incidentsKeep": 30
  },

  "heal": {
    "recurringThreshold": 3,
    "escalateLabel": "needs-human"
  },

  "lark": {
    "cli": "lark-cli",
    "chatId": "oc_756e48ef0507c8f531b62775864e6b09",
    "chatName": "reado情报站"
  }
}
